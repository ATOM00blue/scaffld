[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ command | kebab }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">=3.9"
license = { text = "MIT" }
authors = [{ name = "{{ author }}" }]
dependencies = [
    "typer>=0.12",
    "rich>=13.0",
]

[project.optional-dependencies]
dev = ["pytest>=7.4", "ruff>=0.4"]

[project.scripts]
{{ command }} = "{{ package_name }}.cli:app"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.pytest.ini_options]
testpaths = ["tests"]

[tool.ruff]
line-length = 100
