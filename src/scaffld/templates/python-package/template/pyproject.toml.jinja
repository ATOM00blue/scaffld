[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ package_name | kebab }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_min }}"
{% if license != "None" %}license = { text = "{{ license }}" }
{% endif %}authors = [{ name = "{{ author }}" }]
dependencies = [{% if use_cli %}
    "typer>=0.12",
{% endif %}]

[project.optional-dependencies]
dev = ["pytest>=7.4", "ruff>=0.4"]
{% if use_cli %}
[project.scripts]
{{ package_name | kebab }} = "{{ package_name }}.cli:app"
{% endif %}
[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.pytest.ini_options]
testpaths = ["tests"]

[tool.ruff]
line-length = 100
target-version = "py{{ python_min | replace('.', '') }}"

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B"]
